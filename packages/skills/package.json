{
  "name": "@petagent/skills",
  "version": "0.1.0-m1",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./utils": "./src/skill_utils.ts",
    "./manager": "./src/skill_manager.ts",
    "./indexer": "./src/indexer.ts",
    "./commands": "./src/commands.ts"
  },
  "publishConfig": {
