{
  "name": "@petagent/llm-providers",
  "version": "0.1.0-m2",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./registry": "./src/registry.ts",
    "./transports": "./src/transports.ts",
    "./config": "./src/config_schema.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.6.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
